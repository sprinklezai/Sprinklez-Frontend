# /etc/nginx/sites-available/sales-dashboard
# Adjust server_name and root path, then symlink into sites-enabled.

server {
    listen 80;
    server_name your-domain.com www.your-domain.com;

    root /var/www/sales-dashboard/client/dist;
    index index.html;

    # Serve the built React app; fall back to index.html for client-side routing
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy API calls to the Node/Express process managed by PM2
    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;
}

# After this is enabled, run:
#   certbot --nginx -d your-domain.com -d www.your-domain.com
# to get free auto-renewing HTTPS from Let's Encrypt.
