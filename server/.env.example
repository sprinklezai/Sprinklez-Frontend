# Path to the Google service account JSON key file (see README section 3)
GOOGLE_SERVICE_ACCOUNT_JSON=./config/service-account.json

# Google Drive file IDs (from the file's share URL)
DRIVE_EMPLOYEES_FILE_ID=your_employees_xlsx_file_id
DRIVE_SALES_FILE_ID=your_sales_data_xlsx_file_id

# Any long random string - used to sign login tokens
JWT_SECRET=change_this_to_a_long_random_string

# Port the API listens on
PORT=4000

# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGIN=http://localhost:5173
